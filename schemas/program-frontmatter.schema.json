{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Program frontmatter",
  "type": "object",
  "required": [
    "program_id",
    "title",
    "status",
    "created_at",
    "completed_at",
    "summary",
    "post_build_recap",
    "read_when"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["active", "complete"]
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "completed_at": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "post_build_recap": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "read_when": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": true
}

